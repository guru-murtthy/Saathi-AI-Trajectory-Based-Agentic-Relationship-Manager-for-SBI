# LLM provider for the Agentic RM. Default is fully offline (no keys needed).
SAATHI_LLM_PROVIDER=offline

# Enable a real provider by setting the matching key and provider value:
# SAATHI_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# SAATHI_LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# SAATHI_LLM_PROVIDER=llama
# LLAMA_BASE_URL=http://localhost:11434/v1
# LLAMA_MODEL=llama3
